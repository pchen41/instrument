{
  "name": "instrument-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Instrument — AI SRE console (frontend scaffold)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:db": "node scripts/verify-db.mjs",
    "verify:rls": "node scripts/verify-rls.mjs",
    "verify:reads": "node scripts/verify-reads.mjs"
  },
  "dependencies": {
    "@datadog/browser-rum": "^5.23.3",
    "@insforge/sdk": "^1.0.0",
    "@phosphor-icons/react": "^2.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.19.42",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.6",
    "vitest": "^2.1.1"
  }
}
