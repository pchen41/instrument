# Instrument console — browser-safe frontend environment.
# Copy to `.env.local` and fill in real values. Vite only exposes vars
# prefixed with VITE_ to the browser bundle.
#
# SECURITY: Only browser-safe public values belong here. NEVER put InsForge
# admin/service keys (ik_...), Datadog API/app keys, GitHub PATs, TrueFoundry
# tokens, or any provider secret in this file or any VITE_ variable — they
# would ship to every browser. Server-only secrets live in InsForge secrets /
# the MCP service env, not here.

# --- InsForge (required) ---------------------------------------------------
# Project API base URL.
VITE_INSFORGE_URL=https://m5h8zr7r.us-east.insforge.app
# Browser-safe anonymous key (NOT the admin api_key / ik_... key).
# Retrieve with: npx @insforge/cli secrets get ANON_KEY
VITE_INSFORGE_ANON_KEY=

# --- Datadog RUM (optional) ------------------------------------------------
# Browser-safe RUM client values only. Leave blank to disable frontend RUM —
# the telemetry wrapper becomes a no-op when these are absent. Do NOT use a
# Datadog API key or application key here; RUM uses a client token.
VITE_DD_RUM_APPLICATION_ID=
VITE_DD_RUM_CLIENT_TOKEN=
# e.g. datadoghq.com, datadoghq.eu, us3.datadoghq.com
VITE_DD_RUM_SITE=datadoghq.com
VITE_DD_RUM_SERVICE=instrument-console
# Deployment environment tag (e.g. demo, staging, production).
VITE_DD_RUM_ENV=demo
